# ============================================================
# 依赖 / Dependencies
# ============================================================
node_modules/
.pnp/
.pnp.js
.yarn/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================
# 构建产物 / Build output (Vite / Web / Electron)
# ============================================================
dist/
dist-ssr/
dist-electron/
build/
out/
release/
.vite/
.cache/
.parcel-cache/
*.tsbuildinfo
*.eslintcache

# ============================================================
# 日志 / Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# 环境变量 / Secrets（保留 .env.example 作为模板）
# ============================================================
.env
.env.*
!.env.example
*.local

# ============================================================
# 移动端 / Android (Capacitor)
# ============================================================
android/.gradle/
android/app/build/
android/build/
android/local.properties
*.keystore
*.jks
*.p12

# ============================================================
# 桌面端 / Electron
# ============================================================
electron/dist/
release/

# ============================================================
# Python（训练脚本 / 虚拟环境）
# ============================================================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
scripts/venv/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
douzero-temp/

# ============================================================
# 测试覆盖率 / Coverage
# ============================================================
coverage/
.nyc_output/

# ============================================================
# 编辑器 / IDE
# ============================================================
.vscode/*
!.vscode/extensions.json
.idea/
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
.vs/

# ============================================================
# 操作系统 / OS
# ============================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================
# 大文件 / Git LFS
# 大体积模型与运行时二进制文件（*.wasm / *.onnx / *.onnx.data）
# 由 .gitattributes 交给 Git LFS 管理，此处无需额外规则。
# ============================================================
